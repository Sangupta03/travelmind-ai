# Copy this file to .env and fill in your own values.
# Never commit your real .env file.

# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=

# Google Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Amadeus API (flights) - https://developers.amadeus.com
AMADEUS_API_KEY=
AMADEUS_API_SECRET=

# RapidAPI key (used by tools that go through RapidAPI)
RAPIDAPI_KEY=

# SerpAPI key (Google Hotels search) - https://serpapi.com
SERPAPI_KEY=

# AviationStack API (flight schedule fallback) - https://aviationstack.com
AVIATIONSTACK_KEY=

# Google Maps Platform key (Geocoding, Distance Matrix, Directions, Places)
GOOGLE_MAPS_KEY=

# Optional: Postgres connection string for production (Render/Railway provide this automatically)
# DATABASE_URL=postgres://user:password@host:port/dbname
